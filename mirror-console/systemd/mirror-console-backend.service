[Unit]
Description=Smart Mirror camera console — supervisor (camera arbiter)
After=network.target mosquitto.service

[Service]
Type=simple
User=admin
Group=admin
WorkingDirectory=/home/admin/smartMirror/mirror-console/backend
ExecStart=/usr/bin/python3 /home/admin/smartMirror/mirror-console/backend/supervisor.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
