{
  "name": "mirror-control",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Mirror Control — React + TypeScript + Redux Toolkit companion app for the smart mirror. Talks to the mirror primarily over MQTT (WebSocket); REST only for what MQTT can't carry (camera stream, photo upload).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.7",
    "leaflet": "^1.9.4",
    "mqtt": "^5.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.2"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  }
}
