# Mirror host (the Pi). Used by Vite proxy for REST and as the default MQTT host.
VITE_MIRROR_HTTP=http://10.0.0.249:8000

# MQTT over WebSocket. Requires a mosquitto websocket listener on the Pi
# (see README — listener 9001 / protocol websockets). Leave blank to derive
# ws://<page-host>:9001 at runtime.
VITE_MQTT_URL=ws://10.0.0.249:9001

# Live MagicMirror display (its own web server) embedded on the Home screen.
# Leave blank to derive http://<page-host>:8080 (in dev it derives from
# VITE_MIRROR_HTTP). Requires MagicMirror httpHeaders.frameguard:false.
VITE_MIRROR_DISPLAY_URL=http://10.0.0.249:8080
